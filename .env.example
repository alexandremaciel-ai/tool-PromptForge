# ============================================
# PromptForge — Variáveis de Ambiente
# ============================================
# Copie este arquivo para .env e preencha
# pelo menos UMA API key de provider.
# ============================================

# --- Providers (preencha pelo menos um) ---

# OpenRouter - https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=

# Anthropic - https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

# MiniMax - https://platform.minimax.io/docs/token-plan/intro
MINIMAX_API_KEY=
MINIMAX_MODEL=

# --- Configuração de Provider ---

# Provider padrão para geração de texto: openrouter | anthropic | minimax
DEFAULT_PROVIDER=openrouter

# Provider de fallback para geração de texto: openrouter | anthropic | minimax
FALLBACK_PROVIDER=anthropic

# Provider para embeddings (openrouter recomendado — mais confiável de rate limit)
# Valores: openrouter | minimax
# Se o primário bater rate limit, o sistema faz fallback automático para o outro.
EMBEDDING_PROVIDER=openrouter

# --- Modo Claude Subscription (opcional) ---
# Habilita runtime local com subscrição do Claude.
# Requer ambiente compatível. Não é obrigatório.
CLAUDE_SUBSCRIPTION_ENABLED=false

# --- Aplicação ---

# Porta do servidor
PORT=3000

# Ambiente: development | production | test
NODE_ENV=development

# Tamanho máximo de arquivo em MB
MAX_FILE_SIZE_MB=10

# Número máximo de arquivos por sessão
MAX_FILES_PER_SESSION=3

# Nível de log: debug | info | warn | error
LOG_LEVEL=info

# Supabase 

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
